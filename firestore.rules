rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedInAs(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidCombatPowerRankingEntry(data) {
      return data.keys().hasOnly(['score', 'displayName', 'lastUpdateUtcMs'])
        && data.keys().hasAll(['score', 'displayName', 'lastUpdateUtcMs'])
        && data.score is int
        && data.score >= 0
        && data.score < 999999999
        && data.displayName is string
        && data.displayName.size() <= 30
        && data.lastUpdateUtcMs is int
        && data.lastUpdateUtcMs >= 0;
    }

    match /users/{userId} {
      allow read, write: if signedInAs(userId);

      match /wallet/{walletId} {
        allow read: if signedInAs(userId);
        allow write: if false;
      }

      match /transactions/{transactionId} {
        allow read: if signedInAs(userId);
        allow write: if false;
      }

      match /inventory/{document=**} {
        allow read: if signedInAs(userId);
        allow write: if false;
      }
    }

    match /rankings/combatPower/entries/{uid} {
      allow read: if request.auth != null;
      allow create, update: if signedInAs(uid)
        && isValidCombatPowerRankingEntry(request.resource.data);
      allow delete: if false;
    }
  }
}
